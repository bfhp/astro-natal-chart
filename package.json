{
  "name": "@bfhp/astro-natal-chart",
  "version": "0.1.7",
  "description": "Lightweight astrology natal chart SVG renderer",
  "type": "module",
  "main": "./dist/astro-natal-chart.min.js",
  "module": "./dist/astro-natal-chart.js",
  "exports": {
    ".": {
      "import": "./dist/astro-natal-chart.js",
      "require": "./dist/astro-natal-chart.min.js"
    }
  },
  "scripts": {
    "build": "vite build",
    "precommit": "npm run build",
    "prepare": "npm run build"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "astrology",
    "natal-chart",
    "zodiac",
    "horoscope",
    "svg"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/bfhp/astro-natal-chart"
  },
  "homepage": "https://github.com/bfhp/astro-natal-chart",
  "license": "MIT",
  "sideEffects": false,
  "devDependencies": {
    "vite": "^7.3.1"
  },
  "dependencies": {
    "build": "^0.1.4"
  }
}
